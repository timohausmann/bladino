{
  "name": "dashnet-client-2025",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css}\" \"*.{ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css}\" \"*.{ts,js}\"",
    "preview": "vite preview",
    "analyze": "ANALYZE=true npm run build",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-toast": "^1.2.16",
    "@radix-ui/react-toolbar": "^1.1.13",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.85.5",
    "@tanstack/react-router": "^1.131.8",
    "@tanstack/router-core": "^1.131.7",
    "@tanstack/router-devtools": "^1.131.8",
    "clsx": "^2.1.1",
    "frimousse": "^0.3.0",
    "graphql": "^16.14.1",
    "graphql-request": "^7.4.0",
    "lucide-react": "^0.542.0",
    "motion": "^12.4.10",
    "nanoid": "^5.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.2.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@graphql-codegen/cli": "^7.1.2",
    "@graphql-codegen/client-preset": "^6.0.1",
    "@graphql-codegen/schema-ast": "^6.0.1",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-operations": "^6.0.3",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.13.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^8.0.16",
    "vite-bundle-analyzer": "^1.2.1"
  }
}
